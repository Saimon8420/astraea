# Upstash Redis — distributed rate limiting (optional).
# Create a free database at https://console.upstash.com and paste the REST credentials here.
# If these are absent, Astraea falls back to an in-memory limiter (fine for local dev,
# but not shared across serverless instances in production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Requests allowed per IP per minute (optional, default 60).
RATE_LIMIT_PER_MINUTE=60
