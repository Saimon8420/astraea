{
  "name": "astraea",
  "version": "1.0.0",
  "private": true,
  "description": "Astraea — a free, public Astrology API: natal birth charts, planetary positions, houses, aspects, transits, synastry & interpretations. Powered by astronomy-engine.",
  "author": "Md. Latiful Kabir",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "esbuild src/vercel.ts --bundle --platform=node --format=cjs --target=node20 --outfile=api/index.js",
    "vercel-build": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "astronomy-engine": "^2.1.19",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "luxon": "^3.7.2",
    "tz-lookup": "^6.1.25",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.28.1",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
